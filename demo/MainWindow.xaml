<Window x:Class="AutoFilterWpfDataGridDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        xmlns:autoFilterWpfDataGrid="clr-namespace:AutoFilterWpfDataGrid;assembly=AutoFilterWpfDataGrid"
        Title="DEMO Free mode: 1 filter at a time" WindowStartupLocation="CenterScreen" Width="1550" Height="850">
    <Grid Margin="2">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="AutoFilterWpfDataGrid is a WPF custom control that extends the standard DataGrid to provide advanced, user-friendly filtering and summary features." Margin="2"></TextBlock>
            <TextBlock Text="It automatically generates columns with filter controls in the headers (text boxes, checkboxes, date pickers, etc.) based on the property type of the bound data." Margin="2"></TextBlock>
            <TextBlock Text="It also supports:" Margin="2"></TextBlock>
            <TextBlock Text="• Filtering for all common data types (string, numeric, boolean, enum, DateTime, Guid, TimeSpan)." Margin="2"></TextBlock>
            <TextBlock Text="• 'No value' (null) filtering for nullable types." Margin="2"></TextBlock>
            <TextBlock Text="• Displaying column sums for numeric columns." Margin="2"></TextBlock>
            <TextBlock Text="• Customizable property headers and sum display." Margin="2"></TextBlock>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="5">
            <TextBlock Text="ALL these column header filters are auto generated based on "></TextBlock>
            <TextBlock Text="DataGrid.ItemsSource" FontWeight="Bold"></TextBlock>
        </StackPanel>
        <TextBlock Text="AutoFilterWpfDataGrid (out of the box):" Grid.Row="2" Margin="5" FontWeight="Bold"></TextBlock>
        <!--Demo-->
        <autoFilterWpfDataGrid:AutoFilterWpfDataGrid Name="AutoFilterWpfDataGridControlDemo" Grid.Row="3" Loaded="AutoFilterWpfDataGridControlDemo_Loaded" FiltersChanged="AutoFilterWpfDataGridControlDemo_FiltersChanged"></autoFilterWpfDataGrid:AutoFilterWpfDataGrid>
        <TextBlock Grid.Row="4" Margin="5" FontWeight="Bold">Regular DataGrid:</TextBlock>
        <DataGrid Name="RegularDataGrid" Grid.Row="5"></DataGrid>
    </Grid>
</Window>
